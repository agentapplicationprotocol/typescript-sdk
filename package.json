    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "@hono/node-server": "^1.19.12",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "ai": "^6.0.141",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,json,md}": "oxfmt"
  }
